<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <!--
    Shown after ExitDialog on first install. CODEX_CONFIG_SNIPPET is set by SetCodexSnippetDisplay (JScript)
    so the text shows real [mcp_servers.xplaneMCP] lines without WiX escape sequences.
    Copy uses CopyCodexMcpSnippet.ps1 for clipboard (same TOML as preview).
  -->
  <Fragment>
    <UI>
      <Dialog Id="CodexConfigDlg" Width="370" Height="270" Title="xplaneMCP - Installation complete">
        <Control Id="BottomLine" Type="Line" X="0" Y="234" Width="373" Height="0" />
        <Control
            Id="Title"
            Type="Text"
            X="20"
            Y="15"
            Width="330"
            Height="20"
            Transparent="yes"
            NoPrefix="yes"
            Text="{\WixUI_Font_Title}Configure Codex" />
        <Control
            Id="Description"
            Type="Text"
            X="20"
            Y="40"
            Width="330"
            Height="30"
            Transparent="yes"
            NoPrefix="yes"
            Text="Select the text below to copy, or use the button. Paste into %USERPROFILE%\.codex\config.toml." />
        <!-- WiX v6: Multiline=yes for selection/copy; MSI schema has no ReadOnly on Control (text is prefilled by JScript). -->
        <Control
            Id="ConfigText"
            Type="Edit"
            X="20"
            Y="72"
            Width="330"
            Height="120"
            Property="CODEX_CONFIG_SNIPPET"
            Multiline="yes"
            Sunken="yes" />
        <Control
            Id="CopyClipboard"
            Type="PushButton"
            X="20"
            Y="243"
            Width="120"
            Height="17"
            Text="Copy to Clipboard">
          <Publish Event="DoAction" Value="CopyCodexToClipboard" />
        </Control>
        <Control
            Id="Finish"
            Type="PushButton"
            X="236"
            Y="243"
            Width="56"
            Height="17"
            Default="yes"
            Cancel="yes"
            Text="Finish">
          <Publish Event="EndDialog" Value="Return" />
        </Control>
        <Control Id="Cancel" Type="PushButton" X="304" Y="243" Width="56" Height="17" Disabled="yes" Text="Cancel" />
        <Control Id="Back" Type="PushButton" X="180" Y="243" Width="56" Height="17" Disabled="yes" Text="Back" />
      </Dialog>
    </UI>
  </Fragment>
</Wix>
