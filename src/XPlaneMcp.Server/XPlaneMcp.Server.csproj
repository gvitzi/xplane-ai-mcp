<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <AssemblyName>xplaneMCP</AssemblyName>
    <TargetFramework>net9.0</TargetFramework>
    <!-- Version / FileVersion inherited from repo Directory.Build.props -->
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <!-- Same icon as MSI (resources/xplane_mcp_icon.ico). -->
    <ApplicationIcon>$(MSBuildThisFileDirectory)..\..\resources\xplane_mcp_icon.ico</ApplicationIcon>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.5" />
    <PackageReference Include="ModelContextProtocol" Version="1.2.0" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="XPlaneMcp.Server.Tests" />
  </ItemGroup>

</Project>
